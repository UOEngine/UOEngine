<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:UOEngine.Editor.UI"
    x:Class="UOEngine.Editor.UI.EditorLandingView"
	x:DataType="vm:EditorLandingViewModel">

	<Grid
		  RowSpacing="10"
		  ColumnDefinitions="*,*" RowDefinitions="*,*"  Margin="4">
		
		<Panel Grid.Row="0" Grid.Column="0" Classes="editor-panel"/>

		<StackPanel Grid.Row="0" Grid.Column="1" Spacing="8">
			<TextBlock Text="Open Tool"
					   FontSize="24"
					   FontWeight="Bold" />

			<ItemsControl ItemsSource="{Binding Tools}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Horizontal" Spacing="12" />
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="vm:ToolViewModel">
						<StackPanel Width="96" Spacing="6">
							<Image Source="{Binding Icon}" Width="64" Height="64" HorizontalAlignment="Center" />
							<TextBlock Text="{Binding Name}" HorizontalAlignment="Center" TextAlignment="Center" />
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</StackPanel>
		
		<Panel Grid.Row="1" Grid.Column="0" Classes="editor-panel" />

		<Panel Grid.Row="1" Grid.Column="1" Classes="editor-panel"/>

	</Grid>

</UserControl>